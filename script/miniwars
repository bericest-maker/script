local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer
local playerName = player.Name
local GuiService = game:GetService("GuiService")
local TeleportService = game:GetService("TeleportService")

local function tryTeleport(placeId, jobId, attempts)
    attempts = attempts or 1
    if attempts > 5 then
        print("Teleport failed after 5 attempts")
        return
    end
    
    local success, err = pcall(function()
        if jobId then
            TeleportService:TeleportToPlaceInstance(placeId, jobId, player)
        else
            TeleportService:Teleport(placeId, player)
        end
    end)
    
    if not success then
        print("Teleport attempt " .. attempts .. " failed: " .. tostring(err))
        task.wait(2)
        tryTeleport(placeId, jobId, attempts + 1)
    end
end

local function onErrorMessageChanged(errorMessage)
    if errorMessage and errorMessage ~= "" then
        print("Error detected: " .. errorMessage)
        if player then
            wait()
            tryTeleport(game.PlaceId, game.JobId)
        end
    end
end

GuiService.ErrorMessageChanged:Connect(onErrorMessageChanged)

if syn and syn.queue_on_teleport then
    syn.queue_on_teleport('loadstring(game:HttpGet("https://raw.githubusercontent.com/bericest-maker/script/refs/heads/main/script/miniwars"))()')
elseif queue_on_teleport then
    queue_on_teleport('loadstring(game:HttpGet("https://raw.githubusercontent.com/bericest-maker/script/refs/heads/main/script/miniwars"))()')
elseif fluxus and fluxus.queue_on_teleport then
    fluxus.queue_on_teleport('loadstring(game:HttpGet("https://raw.githubusercontent.com/bericest-maker/script/refs/heads/main/script/miniwars"))()')
end


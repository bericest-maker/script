    SaveKey = "ShopAutoBuy_SaveData_v19",
    RefreshInterval = 2,
    BuyCooldown = 2,
    KOTHDeployInterval = 3,
    AutoSaveInterval = 5,
    UI = {
        Width = 500,
        Height = 400,
        X = 0.5,
        Y = 0.5,
    },
    MapSize = 3000,
    MinZoom = 0.5,
    MaxZoom = 5,
    ZoomStep = 0.2,
    RarityColors = {
        Common = Color3.fromRGB(180, 180, 180),
        Uncommon = Color3.fromRGB(100, 200, 100),
        Rare = Color3.fromRGB(80, 150, 255),
        Epic = Color3.fromRGB(180, 80, 255),
        Legendary = Color3.fromRGB(255, 180, 80),
        Mythic = Color3.fromRGB(255, 80, 80),
        Secret = Color3.fromRGB(255, 50, 50),
        Divine = Color3.fromRGB(255, 215, 0),
    },
    RarityOrder = {
        Divine = 8, Secret = 7, Mythic = 6, Legendary = 5,
        Epic = 4, Rare = 3, Uncommon = 2, Common = 1,
    }
}

local State = {
    running = false, autoRefresh = true, autoBuy = false,
    autoCollect = false, currentTab = "Shop", searchQuery = "",
    myPlot = nil, shopItems = {}, blackMarketItems = {},
    autoBuySelections = {}, connections = {}, threads = {},
    isBlackMarketActive = false, uiElements = {},
    lastBuyTime = 0,
    mapZoom = 1,
    mapPanOffset = {x = 0, y = 0},
    mapIsDragging = false,
    mapDragStart = nil,
    mapPanStart = nil,
    mapBases = {},
    autoKOTH = false,
    mapHovered = false,
}

local Utility = {}

function Utility:Disconnect(connection)
    if connection and typeof(connection) == "RBXScriptConnection" then
        connection:Disconnect()
    end
end

function Utility:DisconnectTable(connections)
    for _, conn in pairs(connections or {}) do
        self:Disconnect(conn)
    end
end

function Utility:CancelThread(thread)
    if thread and coroutine.status(thread) ~= "dead" then
        task.cancel(thread)
    end
end

function Utility:SafeFindFirstChild(parent, ...)
    if not parent then return nil end
    local current = parent
    for _, name in ipairs({...}) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end

function Utility:ExtractAmount(text)
    if not text then return 0 end
    local amount = text:match("x([%d%.]+)")
    if amount then return tonumber(amount) or 0 end
    return 0
end

function Utility:FormatPrice(text)
    if not text or text == "" then return "N/A" end
    text = text:gsub("^%s*", ""):gsub("%s*$", "")
    if text == "" then return "N/A" end
    return text
end

function Utility:SafeGetText(obj)
    if obj and (obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton")) then
        return obj.Text or ""
    end
    return ""
end

function Utility:ParseRarity(text)
    if not text then return "Common" end
    text = text:gsub("%s+", ""):lower()
    local rarities = {"mythic", "legendary", "epic", "rare", "uncommon", "common", "secret", "divine"}
    for _, r in ipairs(rarities) do
        if text:find(r) then return r:sub(1, 1):upper() .. r:sub(2) end
    end
    return "Common"
end

function Utility:GetRarityColor(rarity)
    return CONFIG.RarityColors[rarity] or CONFIG.RarityColors.Common
end

function Utility:GetRarityValue(rarity)
    return CONFIG.RarityOrder[rarity] or 0
end

function Utility:HasStock(stockText)
    if not stockText then return false end
    stockText = stockText:lower()
    if stockText:find("out of stock") then return false end
    if stockText:find("x0") then return false end
    return true
end

local SaveSystem = {}

function SaveSystem:Save()
    local success = pcall(function()
        local data = {
            autoBuySelections = State.autoBuySelections,
            autoBuy = State.autoBuy,
            autoRefresh = State.autoRefresh,
            autoCollect = State.autoCollect,
            autoKOTH = State.autoKOTH,
            version = 19,
        }
        local json = HttpService:JSONEncode(data)
        if writefile then writefile(CONFIG.SaveKey .. ".json", json) end
    end)
    return success
end

function SaveSystem:Load()
    pcall(function()
        if readfile and isfile then
            local path = CONFIG.SaveKey .. ".json"
            if isfile(path) then
                local data = HttpService:JSONDecode(readfile(path))
                if data then
                    State.autoBuySelections = data.autoBuySelections or {}
                    State.autoBuy = data.autoBuy or false
                    State.autoRefresh = data.autoRefresh ~= false
                    State.autoCollect = data.autoCollect or false
                    State.autoKOTH = data.autoKOTH or false
                end
            end
        end
    end)
end

local PlotSystem = {}

function PlotSystem:GetMyPlot()
    local plots = Utility:SafeFindFirstChild(workspace, "MilitaryMap", "PlayerPlots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        local nameObj = Utility:SafeFindFirstChild(plot, "UI", "BillboardGui", "Holder", "PlayerName")
        if nameObj and nameObj:IsA("TextLabel") then
            local owner = nameObj.Text:gsub("'s Empire", "")
            if owner == player.Name then return plot end
        end
    end
    return nil
end

function PlotSystem:RefreshPlot()
    State.myPlot = self:GetMyPlot()
    return State.myPlot
end

local BlackMarketSystem = {}

function BlackMarketSystem:IsActive()
    local door = Utility:SafeFindFirstChild(workspace, "BlackMarket", "Main", "Helicopter", "Door", "Cube.012")
    if not door or not door:IsA("BasePart") then return false end

    local doorClosed = door.Transparency == 0

    -- Time check: active between 15s and 1200s past each hourly interval
    local timeValid = true
    pcall(function()
        local getPreviousCustomInterval = require(ReplicatedStorage.util.getPreviousCustomInterval)
        local v10 = workspace:GetServerTimeNow() - getPreviousCustomInterval(3600)
        timeValid = (v10 >= 15 and v10 <= 1200)
    end)

    return doorClosed and timeValid
end

function BlackMarketSystem:RefreshStatus()
    State.isBlackMarketActive = self:IsActive()
    return State.isBlackMarketActive
end

local ItemParser = {}

function ItemParser:IsValidItem(item)
    if not item or not item:IsA("Frame") then return false end
    if item.Name == "PadderTemplate" or item.Name == "DontDelete" or item.Name == "Template" then return false end
    if item:IsA("UIGridLayout") or item:IsA("UIPadding") or item:IsA("UIListLayout") then return false end
    local hasItemName = item:FindFirstChild("ItemName")
    local hasStock = item:FindFirstChild("Stock")
    local hasRarity = item:FindFirstChild("Rarity")
    local hasBuy = item:FindFirstChild("Buy")
    if not hasItemName or not hasStock or not hasRarity or not hasBuy then return false end
    return true
end

function ItemParser:ParseItem(item)
    if not self:IsValidItem(item) then return nil end
    local itemName = Utility:SafeGetText(item:FindFirstChild("ItemName"))
    local stock = Utility:SafeGetText(item:FindFirstChild("Stock"))
    local rarity = Utility:SafeGetText(item:FindFirstChild("Rarity"))
    local priceText = ""
    local buyBtn = item:FindFirstChild("Buy")
    if buyBtn then
        local priceFrame = buyBtn:FindFirstChild("Price")
        if priceFrame then
            local priceLabel = priceFrame:FindFirstChildWhichIsA("TextLabel", true)
            if priceLabel then priceText = priceLabel.Text end
        end
    end
    if itemName == "" then return nil end

    -- Detect shop category from BuildingsConfig
    local category = "Farm" -- safe default
    pcall(function()
        local BuildingsConfig = require(ReplicatedStorage:FindFirstChild("BuildingsConfig", true))
        local cfg = BuildingsConfig[itemName]
        if cfg then
            -- ShopType overrides Type; skip items flagged dontDisplayInShop
            if cfg.dontDisplayInShop then return end
            category = cfg.ShopType or cfg.Type or category
        end
    end)

    local hasStock = Utility:HasStock(stock)
    local rarityValue = Utility:GetRarityValue(Utility:ParseRarity(rarity))
    local formattedPrice = Utility:FormatPrice(priceText)
    return {
        name = itemName, stock = stock, hasStock = hasStock,
        rarity = Utility:ParseRarity(rarity), rarityText = rarity,
        rarityValue = rarityValue, price = formattedPrice,
        priceFormatted = formattedPrice, rawPrice = priceText,
        category = category,
        instance = item, selected = State.autoBuySelections[itemName] or false,
    }
end

function ItemParser:ScanItems(grid)
    local items = {}
    if not grid or not grid:IsA("GuiObject") then return items end
    for _, child in ipairs(grid:GetChildren()) do
        local parsed = self:ParseItem(child)
        if parsed then table.insert(items, parsed) end
    end
    return items
end

local ShopData = {}

function ShopData:GetShopGrid()
    return Utility:SafeFindFirstChild(player, "PlayerGui", "MainUI", "Fullscreen", "BuyUI", "ItemsGrid")
end

function ShopData:GetBlackMarketGrid()
    return Utility:SafeFindFirstChild(player, "PlayerGui", "MainUI", "Fullscreen", "BlackMarketUI", "ItemsGrid")
end

function ShopData:RefreshShop()
    local grid = self:GetShopGrid()
    State.shopItems = ItemParser:ScanItems(grid)
    self:SortItems(State.shopItems)
    return State.shopItems
end

function ShopData:RefreshBlackMarket()
    BlackMarketSystem:RefreshStatus()
    local grid = self:GetBlackMarketGrid()
    State.blackMarketItems = ItemParser:ScanItems(grid)
    self:SortItems(State.blackMarketItems)
    return State.blackMarketItems
end

function ShopData:SortItems(items)
    table.sort(items, function(a, b)
        if a.hasStock ~= b.hasStock then return a.hasStock end
        if a.rarityValue ~= b.rarityValue then return a.rarityValue > b.rarityValue end
        return a.name < b.name
    end)
end

function ShopData:GetCurrentItems()
    if State.currentTab == "Shop" then return State.shopItems end
    if State.currentTab == "BlackMarket" then return State.blackMarketItems end
    return State.blackMarketItems
end

function ShopData:FilterItems(items, query)
    if not query or query == "" then return items end
    query = query:lower()
    local filtered = {}
    for _, item in ipairs(items) do
        if item.name:lower():find(query, 1, true) then table.insert(filtered, item) end
    end
    return filtered
end

local PurchaseSystem = {}

function PurchaseSystem:FindLiveBuyButton(itemName)
    local grid = nil
    if State.currentTab == "BlackMarket" then
        grid = ShopData:GetBlackMarketGrid()
    else
        grid = ShopData:GetShopGrid()
    end
    
    if not grid then
        print("[AutoBuy] Grid not found for: " .. itemName)
        return nil
    end
    
    for _, child in ipairs(grid:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "PadderTemplate" and child.Name ~= "Template" and child.Name ~= "UIGridLayout" then
            local nameLabel = child:FindFirstChild("ItemName")
            if nameLabel and nameLabel:IsA("TextLabel") and nameLabel.Text == itemName then
                local buyBtn = child:FindFirstChild("Buy")
                if buyBtn and (buyBtn:IsA("TextButton") or buyBtn:IsA("ImageButton")) then
                    return buyBtn
                end
            end
        end
    end
    
    return nil
end

function PurchaseSystem:BuyItem(itemName)
    local now = tick()
    if now - State.lastBuyTime < CONFIG.BuyCooldown then
        return false
    end

    local items = ShopData:GetCurrentItems()
    local targetItem = nil
    for _, item in ipairs(items) do
        if item.name == itemName then
            targetItem = item
            break
        end
    end

    if not targetItem then
        print("[AutoBuy] Item not in list: " .. itemName)
        return false
    end
    if not targetItem.hasStock then
        print("[AutoBuy] Item out of stock: " .. itemName)
        return false
    end

    local isBlackMarket = State.currentTab == "BlackMarket"
    local success = false

    -- PRIMARY: GetBridge (reliable server-side purchase)
    local bridgeOk, bridgeErr = pcall(function()
        local GetBridge = require(ReplicatedStorage.util.GetBridge)
        if isBlackMarket then
            GetBridge("BuyFromBlackMarketShop"):Fire({
                shop = "BlackMarket",
                item = itemName,
            })
        else
            GetBridge("BuyFromShop"):Fire({
                shop = targetItem.category or "Farm",
                item = itemName,
            })
        end
    end)

    if bridgeOk then
        success = true
        print("[AutoBuy] GetBridge purchase: " .. itemName .. (isBlackMarket and " (BlackMarket)" or " (" .. (targetItem.category or "?") .. ")"))
    else
        warn("[AutoBuy] GetBridge failed (" .. tostring(bridgeErr) .. "), falling back to firesignal")
    end

    -- FALLBACK: firesignal on the live UI button
    if not success and firesignal then
        local liveBtn = self:FindLiveBuyButton(itemName)
        if liveBtn then
            local downEvent = liveBtn.MouseButton1Down
            if downEvent and typeof(downEvent) == "RBXScriptSignal" then
                firesignal(downEvent)
                task.wait(0.05)
                local upEvent = liveBtn.MouseButton1Up
                if upEvent and typeof(upEvent) == "RBXScriptSignal" then firesignal(upEvent) end
                task.wait(0.05)
                local clickEvent = liveBtn.MouseButton1Click
                if clickEvent and typeof(clickEvent) == "RBXScriptSignal" then firesignal(clickEvent) end
                success = true
                print("[AutoBuy] firesignal fallback: " .. itemName)
            end
        else
            print("[AutoBuy] No live buy button found for: " .. itemName)
        end
    end

    if success then
        State.lastBuyTime = tick()
        task.wait(0.5)
    end

    return success
end

function PurchaseSystem:AutoBuy()
    if not State.autoBuy then return end
    local items = ShopData:GetCurrentItems()

    print("[AutoBuy] Starting. Items: " .. #items)

    for _, item in ipairs(items) do
        if State.autoBuySelections[item.name] and item.hasStock then
            print("[AutoBuy] Trying: " .. item.name)
            local bought = self:BuyItem(item.name)
            if bought then
                task.wait(CONFIG.BuyCooldown)
            end
        end
    end
end

local CollectSystem = {}

function CollectSystem:HasValue(prompt)
    local text = (prompt.ObjectText or "") .. " " .. (prompt.ActionText or "")
    local amount = Utility:ExtractAmount(text)
    return amount > 0
end

function CollectSystem:GetTargetPriority(building, prompt, hrp)
    local text = (prompt.ObjectText or "") .. " " .. (prompt.ActionText or "")
    local amount = Utility:ExtractAmount(text)
    local isGemMine = building.Name == "GemMine"
    local pos = building:GetPivot().Position
    return {building = building, prompt = prompt, pos = pos, value = amount, gem = isGemMine, dist = (pos - hrp.Position).Magnitude}
end

function CollectSystem:GetBestTargets(hrp)
    -- Scan ALL ProximityPrompts in workspace — server enforces ownership, so safe to attempt any
    local targets = {}
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and self:HasValue(desc) then
            local part = desc.Parent
            local ok, pos = pcall(function()
                if part.GetPivot then return part:GetPivot().Position end
                return part.Position
            end)
            if ok and pos then
                local dist = (pos - hrp.Position).Magnitude
                local text = (desc.ObjectText or "") .. " " .. (desc.ActionText or "")
                table.insert(targets, {
                    building = part, prompt = desc, pos = pos,
                    value = Utility:ExtractAmount(text),
                    gem = part.Name == "GemMine",
                    dist = dist,
                })
            end
        end
    end
    table.sort(targets, function(a, b)
        if a.gem ~= b.gem then return a.gem end
        if a.value ~= b.value then return a.value > b.value end
        return a.dist < b.dist
    end)
    return targets
end

function CollectSystem:CollectLoop()
    while State.autoCollect do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then
            task.wait(1)
            continue
        end
        local targets = self:GetBestTargets(hrp)
        if #targets > 0 then
            local target = targets[1]
            hum:MoveTo(target.pos)
            task.wait(0.5)
            pcall(function() fireproximityprompt(target.prompt) end)
            task.wait(0.2)
        else
            task.wait(1)
        end
    end
end

-- ===== MAP SYSTEM =====
local MapSystem = {}

function MapSystem:scanBases()
    local bases = {}
    local militaryMap = Workspace:FindFirstChild("MilitaryMap")
    if not militaryMap then return bases end
    
    for _, obj in ipairs(militaryMap:GetDescendants()) do
        if obj:IsA("Model") and obj:GetAttribute("Owner") ~= nil then
            local owner = obj:GetAttribute("Owner")
            local baseType = obj:GetAttribute("baseType") or "Unknown"
            local primaryPart = obj.PrimaryPart
            local pos = primaryPart and primaryPart.Position or obj:GetPivot().Position
            
            table.insert(bases, {
                name = obj.Name,
                instance = obj,
                owner = owner,
                baseType = baseType,
                position = pos,
                isMine = (owner == playerName),
                isUnclaimed = (owner == "" or owner == "server" or owner == nil),
            })
        end
    end
    
    return bases
end

function MapSystem:worldToMap(pos)
    local mapSize = CONFIG.MapSize / State.mapZoom
    local center = Vector3.new(0, 0, 0)
    local relative = pos - center
    local mapX = (relative.X / mapSize) + 0.5 + State.mapPanOffset.x
    local mapY = (relative.Z / mapSize) + 0.5 + State.mapPanOffset.y
    return mapX, mapY
end

function MapSystem:captureBase(base)
    if not base or not base.instance or not base.instance.Parent then return false end
    local ok, GetBridge = pcall(function()
        return require(ReplicatedStorage.util.GetBridge)
    end)
    if not ok or not GetBridge then
        warn("[MapCapture] GetBridge not available: " .. tostring(GetBridge))
        return false
    end
    pcall(function()
        GetBridge("SendRocketsToPoint"):Fire({capturePoint = base.instance})
    end)
    task.wait(0.05)
    for i = 1, 4 do
        pcall(function()
            GetBridge("SendTroopsToPoint"):Fire({armyIndex = i, capturePoint = base.instance})
        end)
        task.wait(0.05)
    end
    return true
end

-- ===== KING OF THE HILL SYSTEM =====
local KOTHSystem = {}

function KOTHSystem:getKOTHModels()
    local models = {}
    local specialFolder = Utility:SafeFindFirstChild(workspace, "MilitaryMap", "Object", "Special")
    if not specialFolder then return models end
    for _, child in ipairs(specialFolder:GetChildren()) do
        if child:IsA("Model") and (child.Name == "KingOfTheHillBase" or child.Name == "ToxicKingOfTheHillBase") then
            table.insert(models, {
                name = child.Name == "ToxicKingOfTheHillBase" and "Toxic King of the Hill" or "King of the Hill",
                instance = child,
                baseType = child:GetAttribute("baseType") or child.Name,
                isToxic = child.Name == "ToxicKingOfTheHillBase",
            })
        end
    end
    return models
end

function KOTHSystem:deployToKOTH(kothModel)
    if not kothModel or not kothModel.Parent then return false end
    local ok, GetBridge = pcall(function()
        return require(ReplicatedStorage.util.GetBridge)
    end)
    if not ok or not GetBridge then
        warn("[KOTH] GetBridge not available: " .. tostring(GetBridge))
        return false
    end
    pcall(function()
        GetBridge("SendRocketsToPoint"):Fire({capturePoint = kothModel})
    end)
    task.wait(0.05)
    for i = 1, 4 do
        pcall(function()
            GetBridge("SendTroopsToPoint"):Fire({armyIndex = i, capturePoint = kothModel})
        end)
        task.wait(0.05)
    end
    return true
end

function KOTHSystem:AutoKOTHLoop()
    while State.running do
        if State.autoKOTH then
            local kothModels = self:getKOTHModels()
            for _, model in ipairs(kothModels) do
                self:deployToKOTH(model.instance)
            end
        end
        task.wait(15)
    end
end

function KOTHSystem:TownReturnLoop()
    local hadKOTH = false
    while State.running do
        local hasKOTH = false
        pcall(function()
            local special = workspace.MilitaryMap.Object.Special
            for _, child in ipairs(special:GetChildren()) do
                if child.Name == "KingOfTheHillBase" or child.Name == "ToxicKingOfTheHillBase" then
                    hasKOTH = true
                    break
                end
            end
        end)
        if hadKOTH and not hasKOTH then
            -- KOTH event ended — recall all forces to town
            pcall(function()
                local GetBridge = require(ReplicatedStorage.util.GetBridge)
                local town = workspace.MilitaryMap.Object.MilitaryTown.Town
                GetBridge("SendRocketsToPoint"):Fire({capturePoint = town})
                for i = 1, 4 do
                    GetBridge("SendTroopsToPoint"):Fire({armyIndex = i, capturePoint = town})
                    task.wait(0.05)
                end
                print("[KOTH] Event ended — all forces recalled to town")
            end)
        end
        hadKOTH = hasKOTH
        task.wait(10)
    end
end

-- ===== UI SYSTEM =====
local UI = {}

function UI:Create(className, properties)
    local success, obj = pcall(function()
        local instance = Instance.new(className)
        for prop, value in pairs(properties or {}) do
            if prop ~= "Parent" then instance[prop] = value end
        end
        return instance
    end)
    if success then return obj else return nil end
end

function UI:SetupDraggable(frame, handle)
    local dragging = false
    local dragStart, startPos
    local inputBegan = handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    local inputChanged = handle.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    local inputEnded = handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    table.insert(State.connections, inputBegan)
    table.insert(State.connections, inputChanged)
    table.insert(State.connections, inputEnded)
end

function UI:Build()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then playerGui = player:WaitForChild("PlayerGui", 5) end
    if not playerGui then return nil end
    local existing = playerGui:FindFirstChild("ModularShopUI")
    if existing then existing:Destroy() end
    local gui = self:Create("ScreenGui", {Name = "ModularShopUI", ResetOnSpawn = false, ZIndexBehavior = Enum.ZIndexBehavior.Sibling, Enabled = true})
    if not gui then return nil end
    gui.Parent = playerGui
    local mainFrame = self:Create("Frame", {Name = "MainFrame", Size = UDim2.fromOffset(CONFIG.UI.Width, CONFIG.UI.Height), Position = UDim2.new(CONFIG.UI.X, -CONFIG.UI.Width/2, CONFIG.UI.Y, -CONFIG.UI.Height/2), BackgroundColor3 = Color3.fromRGB(20, 22, 26), BackgroundTransparency = 0.55, BorderSizePixel = 0, ClipsDescendants = true, Visible = true})
    if not mainFrame then return nil end
    mainFrame.Parent = gui
    local corner = self:Create("UICorner", {CornerRadius = UDim.new(0, 4)})
    if corner then corner.Parent = mainFrame end

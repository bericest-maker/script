function UI:CreateItemRow(item, index)
    local container = State.uiElements.listContainer
    if not container then return nil end
    local rowBg = index % 2 == 0 and Color3.fromRGB(30, 33, 42) or Color3.fromRGB(22, 24, 31)
    local row = self:Create("Frame", {Name = "Item_" .. item.name:gsub("[^%w]", "_"), Size = UDim2.new(1, -10, 0, 28), BackgroundColor3 = rowBg, BackgroundTransparency = 0.72, BorderSizePixel = 0, LayoutOrder = index})
    if not row then return nil end
    row.Parent = container
    local rowCorner = self:Create("UICorner", {CornerRadius = UDim.new(0, 5)})
    if rowCorner then rowCorner.Parent = row end
    local widths = {0.35, 0.15, 0.2, 0.15, 0.15}
    local offset = 0
    local values = {item.name, item.stock, item.priceFormatted, item.rarity}
    for i = 1, 4 do
        local textColor = i == 4 and Utility:GetRarityColor(item.rarity) or (i == 1 and Color3.fromRGB(205, 210, 218) or Color3.fromRGB(148, 153, 168))
        local label = self:Create("TextLabel", {Size = UDim2.new(widths[i], -4, 1, 0), Position = UDim2.new(offset, 2, 0, 0), BackgroundTransparency = 1, Text = values[i], TextColor3 = textColor, TextSize = 11, Font = i == 1 and Enum.Font.GothamSemibold or Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd})
        if label then label.Parent = row end
        offset = offset + widths[i]
    end
    local checkbox = self:Create("TextButton", {Name = "AutoBuyCheckbox", Size = UDim2.new(widths[5], -8, 0.68, 0), Position = UDim2.new(offset, 4, 0.16, 0), BackgroundColor3 = item.selected and Color3.fromRGB(42, 118, 62) or Color3.fromRGB(32, 35, 45), Text = item.selected and "✓" or "", TextColor3 = Color3.fromRGB(180, 225, 185), TextSize = 13, Font = Enum.Font.GothamBold})
    if checkbox then
        checkbox.Parent = row
        local cbCorner = self:Create("UICorner", {CornerRadius = UDim.new(0, 4)})
        if cbCorner then cbCorner.Parent = checkbox end
        local cbStroke = self:Create("UIStroke", {Color = Color3.fromRGB(55, 60, 76), Thickness = 1})
        if cbStroke then cbStroke.Parent = checkbox end
        checkbox.MouseButton1Click:Connect(function()
            item.selected = not item.selected
            State.autoBuySelections[item.name] = item.selected
            checkbox.Text = item.selected and "✓" or ""
            checkbox.BackgroundColor3 = item.selected and Color3.fromRGB(42, 118, 62) or Color3.fromRGB(32, 35, 45)
        end)
    end
    return row
end

function UI:CreateMapDot(base)
    local container = State.uiElements.mapContainer
    if not container then return nil end
    
    local existing = container:FindFirstChild("Base_" .. base.name)
    if existing then existing:Destroy() end
    
    local mapX, mapY = MapSystem:worldToMap(base.position)
    
    local dotSize = base.isMine and 20 or 10
    local dotColor = base.isMine and Color3.fromRGB(80, 200, 120)
                   or (base.isUnclaimed and Color3.fromRGB(150, 150, 150) or Color3.fromRGB(200, 80, 80))
    
    local dotContainer = self:Create("Frame", {
        Name = "Base_" .. base.name,
        Size = UDim2.new(0, math.max(dotSize, 80), 0, dotSize + 18),
        Position = UDim2.new(mapX, -(math.max(dotSize, 80)/2), mapY, -(dotSize/2)),
        BackgroundTransparency = 1,
    })
    if not dotContainer then return nil end
    dotContainer.Parent = container
    
    local dot = self:Create("Frame", {
        Name = "Dot",
        Size = UDim2.new(0, dotSize, 0, dotSize),
        Position = UDim2.new(0.5, -(dotSize/2), 0, 0),
        BackgroundColor3 = dotColor,
        BorderSizePixel = 0,
    })
    dot.Parent = dotContainer
    
    local dotCorner = self:Create("UICorner", {CornerRadius = UDim.new(1, 0)})
    if dotCorner then dotCorner.Parent = dot end
    
    if base.isMine then
        local glow = self:Create("Frame", {
            Name = "Glow",
            Size = UDim2.new(0, dotSize + 8, 0, dotSize + 8),
            Position = UDim2.new(0, -4, 0, -4),
            BackgroundColor3 = dotColor,
            BackgroundTransparency = 0.6,
            BorderSizePixel = 0,
            ZIndex = -1,
        })
        if glow then
            glow.Parent = dot
            local glowCorner = self:Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            if glowCorner then glowCorner.Parent = glow end
        end
    end
    
    local dotStroke = self:Create("UIStroke", {
        Color = Color3.fromRGB(255, 255, 255),
        Thickness = base.isMine and 2 or 1,
    })
    if dotStroke then dotStroke.Parent = dot end
    
    local labelText = base.isMine and (playerName .. " ♦ " .. base.name) or base.name
    local labelColor = base.isMine and Color3.fromRGB(80, 200, 120) or Color3.fromRGB(255, 255, 255)
    
    local label = self:Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, 0, 0, 14),
        Position = UDim2.new(0, 0, 0, dotSize + 2),
        BackgroundTransparency = 1,
        Text = labelText,
        TextColor3 = labelColor,
        TextSize = base.isMine and 10 or 8,
        Font = base.isMine and Enum.Font.GothamBold or Enum.Font.Gotham,
        TextStrokeTransparency = 0.5,
        TextXAlignment = Enum.TextXAlignment.Center,
    })
    label.Parent = dotContainer
    
    if not base.isMine then
        local captureBtn = self:Create("TextButton", {
            Name = "CaptureBtn",
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
        })
        captureBtn.Parent = dotContainer
        
        captureBtn.MouseButton1Click:Connect(function()
            print("[Map] Attacking: " .. base.name .. " (Owner: " .. tostring(base.owner) .. ")")
            MapSystem:captureBase(base)
        end)
        
        captureBtn.MouseEnter:Connect(function()
            dot.Size = UDim2.new(0, dotSize + 4, 0, dotSize + 4)
            dot.Position = UDim2.new(0.5, -((dotSize + 4)/2), 0, -2)
            label.TextColor3 = Color3.fromRGB(255, 200, 100)
        end)
        captureBtn.MouseLeave:Connect(function()
            dot.Size = UDim2.new(0, dotSize, 0, dotSize)
            dot.Position = UDim2.new(0.5, -(dotSize/2), 0, 0)
            label.TextColor3 = labelColor
        end)
    end
    
    return dotContainer
end

function UI:ClearItems()
    local container = State.uiElements.listContainer
    if not container then return end
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "HeaderRow" and child.Name ~= "UIListLayout" then
            child:Destroy()
        end
    end
end

function UI:ClearMapDots()
    local container = State.uiElements.mapContainer
    if not container then return end
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "MapGrid" and child.Name ~= "CenterMarker" and child.Name ~= "MapZoomOut" and child.Name ~= "MapZoomIn" and child.Name ~= "MapZoomLabel" and child.Name ~= "MapResetBtn" and child.Name ~= "MapLegend" and child.Name ~= "KOTHPanel" then
            child:Destroy()
        end
    end
end

function UI:UpdateList(items)
    self:ClearItems()
    for i, item in ipairs(items) do
        self:CreateItemRow(item, i)
    end
end

function UI:UpdateMap(bases)
    self:ClearMapDots()
    
    for _, base in ipairs(bases) do
        self:CreateMapDot(base)
    end
    
    if State.uiElements.mapCountLabel then
        local mineCount = 0
        local enemyCount = 0
        for _, b in ipairs(bases) do
            if b.isMine then mineCount += 1
            elseif not b.isUnclaimed then enemyCount += 1 end
        end
        State.uiElements.mapCountLabel.Text = string.format("Yours: %d | Enemy: %d", mineCount, enemyCount)
    end
    
    if State.uiElements.mapZoomLabel then
        State.uiElements.mapZoomLabel.Text = math.floor(State.mapZoom * 100) .. "%"
    end
end

function UI:UpdateTabColors()
    if not State.uiElements.shopTab then return end
    -- Active tab is slightly more visible; inactive stays near-invisible
    local activeTransp   = 0.75
    local inactiveTransp = 0.92
    local activeText    = Color3.fromRGB(210, 215, 220)
    local inactiveText  = Color3.fromRGB(100, 105, 122)

    State.uiElements.shopTab.BackgroundTransparency = State.currentTab == "Shop" and activeTransp or inactiveTransp
    State.uiElements.shopTab.TextColor3             = State.currentTab == "Shop" and activeText  or inactiveText

    if State.uiElements.blackMarketTab then
        State.uiElements.blackMarketTab.BackgroundTransparency = State.currentTab == "BlackMarket" and activeTransp or inactiveTransp
        State.uiElements.blackMarketTab.TextColor3             = State.currentTab == "BlackMarket" and activeText  or inactiveText
    end
    if State.uiElements.mapTab then
        State.uiElements.mapTab.BackgroundTransparency = State.currentTab == "Map" and activeTransp or inactiveTransp
        State.uiElements.mapTab.TextColor3             = State.currentTab == "Map" and activeText  or inactiveText
    end
end

function UI:UpdateToggleColors()
    if not State.uiElements.refreshToggle then return end
    local onColor  = Color3.fromRGB(42, 118, 62)
    local offColor = Color3.fromRGB(100, 32, 32)

    State.uiElements.refreshToggle.BackgroundColor3 = State.autoRefresh and onColor or offColor
    State.uiElements.refreshToggle.Text = State.autoRefresh and "Auto Refresh: ON" or "Auto Refresh: OFF"
    State.uiElements.buyToggle.BackgroundColor3 = State.autoBuy and onColor or offColor
    State.uiElements.buyToggle.Text = State.autoBuy and "Auto Buy: ON" or "Auto Buy: OFF"
    State.uiElements.collectToggle.BackgroundColor3 = State.autoCollect and onColor or offColor
    State.uiElements.collectToggle.Text = State.autoCollect and "Auto Collect: ON" or "Auto Collect: OFF"

    if State.uiElements.autoKOTHToggle then
        State.uiElements.autoKOTHToggle.BackgroundColor3 = State.autoKOTH and onColor or offColor
        State.uiElements.autoKOTHToggle.Text = State.autoKOTH and "Auto Deploy: ON" or "Auto Deploy: OFF"
    end
end

function UI:ShowShop()
    if State.uiElements.listContainer then
        State.uiElements.listContainer.Visible = true
    end
    if State.uiElements.mapContainer then
        State.uiElements.mapContainer.Visible = false
    end
    if State.uiElements.searchBox then
        State.uiElements.searchBox.Visible = true
    end
    if State.uiElements.mapLegend then
        State.uiElements.mapLegend.Visible = false
    end
    if State.uiElements.mapZoomIn then
        State.uiElements.mapZoomIn.Visible = false
    end
    if State.uiElements.mapZoomOut then
        State.uiElements.mapZoomOut.Visible = false
    end
    if State.uiElements.mapZoomLabel then
        State.uiElements.mapZoomLabel.Visible = false
    end
    if State.uiElements.mapResetBtn then
        State.uiElements.mapResetBtn.Visible = false
    end
    if State.uiElements.kothPanel then
        State.uiElements.kothPanel.Visible = false
    end
    if State.uiElements.bmInactiveOverlay then
        State.uiElements.bmInactiveOverlay.Visible = false
    end
end

function UI:ShowBlackMarket()
    if State.uiElements.mapContainer then
        State.uiElements.mapContainer.Visible = false
    end
    if State.uiElements.searchBox then
        State.uiElements.searchBox.Visible = true
    end
    if State.uiElements.mapLegend then
        State.uiElements.mapLegend.Visible = false
    end
    if State.uiElements.mapZoomIn then
        State.uiElements.mapZoomIn.Visible = false
    end
    if State.uiElements.mapZoomOut then
        State.uiElements.mapZoomOut.Visible = false
    end
    if State.uiElements.mapZoomLabel then
        State.uiElements.mapZoomLabel.Visible = false
    end
    if State.uiElements.mapResetBtn then
        State.uiElements.mapResetBtn.Visible = false
    end
    if State.uiElements.kothPanel then
        State.uiElements.kothPanel.Visible = false
    end

    BlackMarketSystem:RefreshStatus()

    if State.isBlackMarketActive then
        -- Active: show list, hide overlay
        if State.uiElements.bmInactiveOverlay then
            State.uiElements.bmInactiveOverlay.Visible = false
        end
        if State.uiElements.listContainer then
            State.uiElements.listContainer.Visible = true
        end
        ShopData:RefreshBlackMarket()
        local filtered = ShopData:FilterItems(State.blackMarketItems, State.searchQuery)
        UI:UpdateList(filtered)
    else
        -- Inactive: hide list, show big INACTIVE overlay
        if State.uiElements.listContainer then
            State.uiElements.listContainer.Visible = false
        end
        if State.uiElements.bmInactiveOverlay then
            State.uiElements.bmInactiveOverlay.Visible = true
        end
    end
end

function UI:ShowMap()
    if State.uiElements.listContainer then
        State.uiElements.listContainer.Visible = false
    end
    if State.uiElements.mapContainer then
        State.uiElements.mapContainer.Visible = true
    end
    if State.uiElements.searchBox then
        State.uiElements.searchBox.Visible = false
    end
    if State.uiElements.mapLegend then
        State.uiElements.mapLegend.Visible = true
    end
    if State.uiElements.mapZoomIn then
        State.uiElements.mapZoomIn.Visible = true
    end
    if State.uiElements.mapZoomOut then
        State.uiElements.mapZoomOut.Visible = true
    end
    if State.uiElements.mapZoomLabel then
        State.uiElements.mapZoomLabel.Visible = true
    end
    if State.uiElements.mapResetBtn then
        State.uiElements.mapResetBtn.Visible = true
    end
    if State.uiElements.kothPanel then
        State.uiElements.kothPanel.Visible = true
    end
    if State.uiElements.bmInactiveOverlay then
        State.uiElements.bmInactiveOverlay.Visible = false
    end

    local bases = MapSystem:scanBases()
    UI:UpdateMap(bases)
end

function UI:Destroy()
    if State.uiElements and State.uiElements.gui then
        State.uiElements.gui:Destroy()
    end
    Utility:DisconnectTable(State.connections)
    for _, thread in pairs(State.threads) do
        Utility:CancelThread(thread)
    end
    State.running = false
    State.autoCollect = false
    State.autoRefresh = false
    State.autoKOTH = false
    State.uiElements = {}
end

-- ===== EVENT HANDLERS =====
local EventHandlers = {}

function EventHandlers:Setup()
    local elems = State.uiElements
    if not elems then return end
    if elems.closeBtn then
        table.insert(State.connections, elems.closeBtn.MouseButton1Click:Connect(function()
            SaveSystem:Save()
            UI:Destroy()
        end))
    end
    -- Minimize: snap mini button to where the minimize button is on screen, then hide main frame
    if elems.minimizeBtn then
        table.insert(State.connections, elems.minimizeBtn.MouseButton1Click:Connect(function()
            local mf = elems.mainFrame
            local mb = elems.miniBtn
            local minBtn = elems.minimizeBtn
            if mf and mb and minBtn then
                -- Position the mini button exactly where the minimize button is on screen
                local absPos = minBtn.AbsolutePosition
                mb.Position = UDim2.fromOffset(absPos.X, absPos.Y)
                mf.Visible = false
                mb.Visible = true
            end
        end))
    end
    -- Mini open button: restore main frame
    if elems.miniBtn then
        table.insert(State.connections, elems.miniBtn.MouseButton1Click:Connect(function()
            if elems.miniBtn then elems.miniBtn.Visible = false end
            if elems.mainFrame then elems.mainFrame.Visible = true end
        end))
    end
    if elems.shopTab then
        table.insert(State.connections, elems.shopTab.MouseButton1Click:Connect(function()
            State.currentTab = "Shop"
            UI:UpdateTabColors()
            UI:ShowShop()
            self:RefreshAndUpdate()
        end))
    end
    -- ===== BLACK MARKET TAB HANDLER =====
    if elems.blackMarketTab then
        table.insert(State.connections, elems.blackMarketTab.MouseButton1Click:Connect(function()
            State.currentTab = "BlackMarket"
            UI:UpdateTabColors()
            UI:ShowBlackMarket()
        end))
    end
    if elems.mapTab then
        table.insert(State.connections, elems.mapTab.MouseButton1Click:Connect(function()
            State.currentTab = "Map"
            UI:UpdateTabColors()
            UI:ShowMap()
        end))
    end
    if elems.searchBox then
        table.insert(State.connections, elems.searchBox:GetPropertyChangedSignal("Text"):Connect(function()
            State.searchQuery = elems.searchBox.Text
            self:RefreshAndUpdate()
        end))
    end
    if elems.refreshToggle then
        table.insert(State.connections, elems.refreshToggle.MouseButton1Click:Connect(function()
            State.autoRefresh = not State.autoRefresh
            UI:UpdateToggleColors()
            SaveSystem:Save()
        end))
    end
    if elems.buyToggle then
        table.insert(State.connections, elems.buyToggle.MouseButton1Click:Connect(function()
            State.autoBuy = not State.autoBuy
            UI:UpdateToggleColors()
            SaveSystem:Save()
        end))
    end
    if elems.collectToggle then
        table.insert(State.connections, elems.collectToggle.MouseButton1Click:Connect(function()
            State.autoCollect = not State.autoCollect
            UI:UpdateToggleColors()
            SaveSystem:Save()
            if State.autoCollect then
                local thread = task.spawn(CollectSystem.CollectLoop, CollectSystem)
                table.insert(State.threads, thread)
            end
        end))
    end
    if elems.saveBtn then
        table.insert(State.connections, elems.saveBtn.MouseButton1Click:Connect(function()
            local success = SaveSystem:Save()
            elems.saveBtn.Text = success and "Saved!" or "Error"
            task.wait(1)
            elems.saveBtn.Text = "Save"
        end))
    end
    if elems.loadBtn then
        table.insert(State.connections, elems.loadBtn.MouseButton1Click:Connect(function()
            SaveSystem:Load()
            for itemName, selected in pairs(State.autoBuySelections) do
                print("Loaded: " .. itemName .. " = " .. tostring(selected))
            end
            elems.loadBtn.Text = "Loaded!"
            self:RefreshAndUpdate()
            task.wait(1)
            elems.loadBtn.Text = "Load"
        end))
    end
    
    -- Map zoom controls
    if elems.mapZoomIn then
        table.insert(State.connections, elems.mapZoomIn.MouseButton1Click:Connect(function()
            State.mapZoom = math.min(State.mapZoom + CONFIG.ZoomStep, CONFIG.MaxZoom)
            local bases = MapSystem:scanBases()
            UI:UpdateMap(bases)
        end))
    end
    
    if elems.mapZoomOut then
        table.insert(State.connections, elems.mapZoomOut.MouseButton1Click:Connect(function()
            State.mapZoom = math.max(State.mapZoom - CONFIG.ZoomStep, CONFIG.MinZoom)
            local bases = MapSystem:scanBases()
            UI:UpdateMap(bases)
        end))
    end
    
    if elems.mapResetBtn then
        table.insert(State.connections, elems.mapResetBtn.MouseButton1Click:Connect(function()
            State.mapZoom = 1
            State.mapPanOffset = {x = 0, y = 0}
            local bases = MapSystem:scanBases()
            UI:UpdateMap(bases)
        end))
    end
    
    -- KOTH Toggle Buttons
    if elems.autoKOTHToggle then
        table.insert(State.connections, elems.autoKOTHToggle.MouseButton1Click:Connect(function()
            State.autoKOTH = not State.autoKOTH
            UI:UpdateToggleColors()
            SaveSystem:Save()
            print("[KOTH] Auto Deploy: " .. tostring(State.autoKOTH))
        end))
    end

    
    -- Map panning
    if elems.mapContainer then
        local mapContainer = elems.mapContainer
        local inputBegan = mapContainer.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                State.mapIsDragging = true
                State.mapDragStart = input.Position
                State.mapPanStart = {x = State.mapPanOffset.x, y = State.mapPanOffset.y}
            end
        end)
        local inputChanged = mapContainer.InputChanged:Connect(function(input)
            if State.mapIsDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - State.mapDragStart
                local containerSize = mapContainer.AbsoluteSize
                State.mapPanOffset.x = State.mapPanStart.x + (delta.X / containerSize.X)
                State.mapPanOffset.y = State.mapPanStart.y + (delta.Y / containerSize.Y)
                local bases = MapSystem:scanBases()
                UI:UpdateMap(bases)
            end
        end)
        local inputEnded = mapContainer.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                State.mapIsDragging = false
            end
        end)
        table.insert(State.connections, inputBegan)
        table.insert(State.connections, inputChanged)
        table.insert(State.connections, inputEnded)
        
        -- Track hover state for zoom gating
        local hoverEnter = mapContainer.MouseEnter:Connect(function()
            State.mapHovered = true
        end)
        local hoverLeave = mapContainer.MouseLeave:Connect(function()
            State.mapHovered = false
        end)
        table.insert(State.connections, hoverEnter)
        table.insert(State.connections, hoverLeave)

        pcall(function()
            local wheelConn = game:GetService("UserInputService").InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseWheel
                    and State.currentTab == "Map"
                    and State.mapHovered then
                    if input.Position.Z > 0 then
                        State.mapZoom = math.min(State.mapZoom + CONFIG.ZoomStep, CONFIG.MaxZoom)
                    else
                        State.mapZoom = math.max(State.mapZoom - CONFIG.ZoomStep, CONFIG.MinZoom)
                    end
                    local bases = MapSystem:scanBases()
                    UI:UpdateMap(bases)
                end
            end)
            table.insert(State.connections, wheelConn)
        end)
    end
end

function EventHandlers:RefreshAndUpdate()
    if State.currentTab == "Shop" then
        ShopData:RefreshShop()
        local filtered = ShopData:FilterItems(State.shopItems, State.searchQuery)
        UI:UpdateList(filtered)
    elseif State.currentTab == "BlackMarket" then
        BlackMarketSystem:RefreshStatus()
        if State.isBlackMarketActive then
            if State.uiElements.bmInactiveOverlay then
                State.uiElements.bmInactiveOverlay.Visible = false
            end
            if State.uiElements.listContainer then
                State.uiElements.listContainer.Visible = true
            end
            ShopData:RefreshBlackMarket()
            local filtered = ShopData:FilterItems(State.blackMarketItems, State.searchQuery)
            UI:UpdateList(filtered)
        else
            if State.uiElements.listContainer then
                State.uiElements.listContainer.Visible = false
            end
            if State.uiElements.bmInactiveOverlay then
                State.uiElements.bmInactiveOverlay.Visible = true
            end
        end
    end
end

-- ===== MAIN LOOPS =====
local MainLoop = {}

function MainLoop:StartRefreshLoop()
    local thread = task.spawn(function()
        while State.running do
            if State.autoRefresh and (State.currentTab == "Shop" or State.currentTab == "BlackMarket") then
                EventHandlers:RefreshAndUpdate()
            end
            task.wait(CONFIG.RefreshInterval)
        end
    end)
    table.insert(State.threads, thread)
end

function MainLoop:StartAutoBuyLoop()
    local thread = task.spawn(function()
        while State.running do
            if State.autoBuy then
                PurchaseSystem:AutoBuy()
            end
            task.wait(1)
        end
    end)
    table.insert(State.threads, thread)
end

function MainLoop:StartMapUpdateLoop()
    local thread = task.spawn(function()
        while State.running do
            if State.currentTab == "Map" then
                local bases = MapSystem:scanBases()
                UI:UpdateMap(bases)
            end
            task.wait(3)
        end
    end)
    table.insert(State.threads, thread)
end

function MainLoop:StartKOTHLoops()
    local kothThread = task.spawn(function()
        KOTHSystem:AutoKOTHLoop()
    end)
    table.insert(State.threads, kothThread)
    local townThread = task.spawn(function()
        KOTHSystem:TownReturnLoop()
    end)
    table.insert(State.threads, townThread)
end

function MainLoop:StartAutoSaveLoop()
    local thread = task.spawn(function()
        while State.running do
            task.wait(CONFIG.AutoSaveInterval)
            SaveSystem:Save()
            print("[AutoSave] Saved settings")
        end
    end)
    table.insert(State.threads, thread)
end

-- ===== INITIALIZE =====
local function Initialize()
    SaveSystem:Load()
    local success, result = pcall(function()
        UI:Build()
    end)
    if not success then
        warn("UI Build failed: " .. tostring(result))
        return
    end
    if not State.uiElements or not State.uiElements.gui then
        warn("UI elements not created properly")
        return
    end
    EventHandlers:Setup()
    UI:UpdateTabColors()
    UI:UpdateToggleColors()
    UI:ShowShop()
    PlotSystem:RefreshPlot()
    EventHandlers:RefreshAndUpdate()
    State.running = true
    MainLoop:StartRefreshLoop()
    MainLoop:StartAutoBuyLoop()
    MainLoop:StartMapUpdateLoop()
    MainLoop:StartKOTHLoops()
    MainLoop:StartAutoSaveLoop()
    if State.autoCollect then
        local thread = task.spawn(CollectSystem.CollectLoop, CollectSystem)
        table.insert(State.threads, thread)
    end
    -- Auto-execute: send all forces to town immediately on script load
    pcall(function()
        local GetBridge = require(ReplicatedStorage.util.GetBridge)
        local town = workspace.MilitaryMap.Object.MilitaryTown.Town
        GetBridge("SendRocketsToPoint"):Fire({capturePoint = town})
        for i = 1, 4 do
            GetBridge("SendTroopsToPoint"):Fire({armyIndex = i, capturePoint = town})
            task.wait(0.05)
        end
        print("[Init] All forces sent to town")
    end)
    print("Shop & Base Map Manager loaded!")
end

player.CharacterRemoving:Connect(function()
    SaveSystem:Save()
end)

Initialize()

return {
    State = State, UI = UI, ShopData = ShopData,
    PurchaseSystem = PurchaseSystem, CollectSystem = CollectSystem, 
    SaveSystem = SaveSystem, MapSystem = MapSystem, KOTHSystem = KOTHSystem,
}

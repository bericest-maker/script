local ListWindow = library:CreateWindow("Shop Items", {
	topcolor = Color3.fromRGB(30, 30, 30);
	underlinecolor = Color3.fromRGB(0, 255, 140);
	bgcolor = Color3.fromRGB(35, 35, 35);
	textcolor = Color3.fromRGB(255, 255, 255);
	font = Enum.Font.SourceSans;
	fontsize = 17;
})

ListWindow:Dropdown("Tab", {list = {"Shop", "BlackMarket"}}, function(selected)
	State.currentTab = selected
	if _G._shopColumnRefresh then
		_G._shopColumnRefresh()
	end
end)

ListWindow:Section("--- Item Controls ---")

local shopColumn = nil
local function refreshItemList()
	if State.currentTab == "Shop" then
		ShopData:RefreshShop()
	else
		ShopData:RefreshBlackMarket()
	end

	local items = ShopData:GetCurrentItems()
	local filtered = ShopData:FilterItems(items, State.searchQuery)

	local names = {}
	for _, item in ipairs(filtered) do
		local selected = State.autoBuySelections[item.name] or false
		local mark = selected and "[x] " or "[ ] "
		table.insert(names, mark .. item.name .. " [" .. item.rarity .. "]")
	end

	if shopColumn then
		shopColumn:Refresh(names)
	end
end

_G._shopColumnRefresh = refreshItemList

shopColumn = ListWindow:Column("Items", {list = {}, maxVisible = 15, itemHeight = 22}, function(selected, rawText)
	local itemName = rawText:match("^%[.%] (.-) %[")
	if itemName then
		State.autoBuySelections[itemName] = not (State.autoBuySelections[itemName] or false)
		SaveSystem:Save()
		refreshItemList()
	end
end)

ListWindow:Button("Refresh Item List", function()
	refreshItemList()
end)

ListWindow:Button("Clear AutoBuy Selections", function()
	State.autoBuySelections = {}
	SaveSystem:Save()
	refreshItemList()
end)

local MapWindow = library:CreateWindow("Base Map", {
	topcolor = Color3.fromRGB(30, 30, 30);
	underlinecolor = Color3.fromRGB(255, 100, 0);
	bgcolor = Color3.fromRGB(35, 35, 35);
	textcolor = Color3.fromRGB(255, 255, 255);
	font = Enum.Font.SourceSans;
	fontsize = 17;
})

MapWindow:Section("--- Base Actions ---")

MapWindow:Button("Capture Nearest Enemy", function()
	local bases = MapSystem:scanBases()
	local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local nearest = nil
	local nearestDist = math.huge
	for _, b in ipairs(bases) do
		if not b.isMine and not b.isUnclaimed then
			local dist = (b.position - hrp.Position).Magnitude
			if dist < nearestDist then nearestDist = dist; nearest = b end
		end
	end
	if nearest then
		MapSystem:captureBase(nearest)
	end
end)

MapWindow:Button("Capture All Unclaimed", function()
	local bases = MapSystem:scanBases()
	for _, b in ipairs(bases) do
		if b.isUnclaimed then
			MapSystem:captureBase(b)
			task.wait(0.2)
		end
	end
end)

MapWindow:Button("Recall All to Town", function()
	pcall(function()
		local GetBridge = require(ReplicatedStorage.util.GetBridge)
		local town = workspace.MilitaryMap.Object.MilitaryTown.Town
		GetBridge("SendRocketsToPoint"):Fire({capturePoint = town})
		for i = 1, 4 do
			GetBridge("SendTroopsToPoint"):Fire({armyIndex = i, capturePoint = town})
			task.wait(0.05)
		end
	end)
end)

MapWindow:Section("--- Plot Info ---")

MapWindow:Button("Refresh My Plot", function()
	PlotSystem:RefreshPlot()
end)

refreshItemList()

